{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/submission.schema.json",
  "title": "Slab Verification Submission",
  "type": "object",
  "required": [
    "submission_id",
    "structure_type",
    "contact",
    "slab_edge_photos",
    "reinforcement_photos",
    "terms_acknowledged"
  ],
  "properties": {
    "submission_id": {
      "type": "string",
      "minLength": 8
    },
    "structure_type": {
      "type": "string",
      "enum": ["pergola", "shed", "garage", "patio", "lanai", "screen_enclosure", "other"]
    },
    "contact": {
      "type": "object",
      "required": ["name", "email", "phone"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string", "minLength": 7 }
      },
      "additionalProperties": false
    },
    "slab_edge_photos": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    },
    "reinforcement_photos": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "measured_thickness_inches": {
      "type": "number",
      "minimum": 1
    },
    "reinforcement_description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "terms_acknowledged": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
